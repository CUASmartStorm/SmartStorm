####### Compile

DatabaseWriter.o: ../DatabaseWriter.cpp ../DatabaseWriter.h \
		../noaaweatherfetcher.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o DatabaseWriter.o ../DatabaseWriter.cpp

DistanceSensor.o: ../DistanceSensor.cpp ../DistanceSensor.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o DistanceSensor.o ../DistanceSensor.cpp

MoistureSensor.o: ../MoistureSensor.cpp ../MoistureSensor.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o MoistureSensor.o ../MoistureSensor.cpp

chartcontainer.o: ../chartcontainer.cpp ../chartcontainer.h \
		../noaaweatherfetcher.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o chartcontainer.o ../chartcontainer.cpp

main.o: ../main.cpp ../smartrainharvest.h \
		../noaaweatherfetcher.h \
		../chartcontainer.h \
		../DistanceSensor.h \
		../MoistureSensor.h \
		../DatabaseWriter.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../main.cpp

noaaweatherfetcher.o: ../noaaweatherfetcher.cpp ../noaaweatherfetcher.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o noaaweatherfetcher.o ../noaaweatherfetcher.cpp

smartrainharvest.o: ../smartrainharvest.cpp ../smartrainharvest.h \
		../noaaweatherfetcher.h \
		../chartcontainer.h \
		../DistanceSensor.h \
		../MoistureSensor.h \
		../DatabaseWriter.h \
		ui_smartrainharvest.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o smartrainharvest.o ../smartrainharvest.cpp

moc_DatabaseWriter.o: moc_DatabaseWriter.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_DatabaseWriter.o moc_DatabaseWriter.cpp

moc_DistanceSensor.o: moc_DistanceSensor.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_DistanceSensor.o moc_DistanceSensor.cpp

moc_MoistureSensor.o: moc_MoistureSensor.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_MoistureSensor.o moc_MoistureSensor.cpp

moc_noaaweatherfetcher.o: moc_noaaweatherfetcher.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_noaaweatherfetcher.o moc_noaaweatherfetcher.cpp

moc_smartrainharvest.o: moc_smartrainharvest.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_smartrainharvest.o moc_smartrainharvest.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/SmartRainHarvest/bin || mkdir -p $(INSTALL_ROOT)/opt/SmartRainHarvest/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/SmartRainHarvest/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/SmartRainHarvest/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/SmartRainHarvest/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/SmartRainHarvest/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

